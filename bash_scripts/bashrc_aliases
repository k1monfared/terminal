## project creation
new_project() {
    # Ask for project name
    echo -n "Enter project name: "
    read project_name

    # Replace spaces with underscores and keep only alphanumeric characters and underscores
    clean_name=$(echo "$project_name" | sed 's/ /_/g' | sed 's/[^a-zA-Z0-9_]//g')

    # Check if directory already exists
    project_path="$HOME/public/$clean_name"
    while [[ -d "$project_path" ]]; do
        echo "Directory already exists: $project_path"
        echo "Contents:"
        ls -la "$project_path"
        echo
        echo -n "Enter a new project name [$clean_name]: "
        read new_name
        if [[ -n "$new_name" ]]; then
            clean_name=$(echo "$new_name" | sed 's/ /_/g' | sed 's/[^a-zA-Z0-9_]//g')
        fi
        project_path="$HOME/public/$clean_name"
    done

    # Create project directory
    mkdir -p "$project_path"

    # Ask if Claude Code template should be used
    echo -n "Use Claude Code template? (y/n): "
    read use_claude

    if [[ "$use_claude" == "y" || "$use_claude" == "Y" ]]; then
        template_path="$HOME/public/claude_code_project_template"
        if [[ -d "$template_path" ]]; then
            cp -r "$template_path"/. "$project_path/"
            echo "Claude Code template copied to $project_path"
        else
            echo "Warning: Claude Code template not found at $template_path"
        fi
    fi

    # Change to project directory and initialize git
    cd "$project_path"
    git init

    # Ask if repository should be public
    echo -n "Make repository public? (y/n, default is private): "
    read make_public

    # Add all files and make initial commit
    git add --all
    git commit -m "Initial commit"

    # Create GitHub repository and push
    if [[ "$make_public" == "y" || "$make_public" == "Y" ]]; then
        gh repo create "$clean_name" --public --source . --remote origin --push
    else
        gh repo create "$clean_name" --private --source . --remote origin --push
    fi

    echo "GitHub repository created and connected"

    # Open readme.log in vscode
    readme_file="$project_path/readme.log"
    if [[ ! -f "$readme_file" ]]; then
        touch "$readme_file"
    fi
    $EDITOR "$readme_file"

    echo "Project '$clean_name' created at $project_path"
}

# library
libby_get ()
{
    # Each book downloads with a "<title-slug>__" filename prefix so multiple books
    # in ~/Downloads do not collide. Process every pending manifest, stripping the
    # prefix as files are moved into "$audiobooks_folder/Author - Title/".
    shopt -s nullglob
    local manifests=("$HOME/Downloads/"*"__libby_manifest.sh")
    # legacy unprefixed manifest from older script versions
    [[ -f "$HOME/Downloads/libby_manifest.sh" ]] && manifests+=("$HOME/Downloads/libby_manifest.sh")
    if (( ${#manifests[@]} == 0 )); then
        echo "No manifest found. Open a book in the Libby web player and click Download."
        return 1
    fi

    local manifest title author metadata input_author dir f src clean
    local -a files
    for manifest in "${manifests[@]}"; do
        title=""; author=""; metadata=""; files=()
        source "$manifest"
        read -rp "Author for \"$title\" [${author:-blank}, enter to keep]: " input_author
        [[ -n "$input_author" ]] && author="$input_author"
        dir="$audiobooks_folder${author:+$author - }$title"
        mkdir -p "$dir"
        for f in "${files[@]}"; do
            src="$HOME/Downloads/$f"
            clean="${f##*__}"          # strip "<slug>__" prefix (no-op for legacy names)
            if [[ -f "$src" ]]; then
                mv "$src" "$dir/$clean"
                echo "Moved: $clean"
            else
                echo "Missing: $f (skipped)"
            fi
        done
        # move the metadata file (nested loglog) downloaded alongside the parts
        if [[ -n "$metadata" && -f "$HOME/Downloads/$metadata" ]]; then
            mv "$HOME/Downloads/$metadata" "$dir/${metadata##*__}"
            echo "Moved: ${metadata##*__}"
        fi
        mv "$manifest" "$dir/libby_manifest.sh"
        echo "Done: $dir"
    done
    ls "$audiobooks_folder" > "$public_notes_folder/audiobooks"
}

# AI tools: provider routing for Claude Code and OpenCode
#   use-poe        / use_poe         : route both tools through Poe
#   use-claude     / use_claude      : Claude Code uses Claude.ai subscription (OAuth); OpenCode falls back to Poe Claude (Anthropic TOS forbids using subscription auth from third-party tools like OpenCode)
#   use-claude-api / use_claude_api  : route both tools to direct Anthropic API (uses CLAUDE_API_KEY; needs credits at console.anthropic.com)
#   check-claude-config              : print current routing

# Helper: write the default model into ~/.config/opencode/opencode.json
_set_opencode_model() {
    local model="$1"
    local cfg="$HOME/.config/opencode/opencode.json"
    mkdir -p "$(dirname "$cfg")"
    python3 - "$cfg" "$model" <<'PY'
import json, sys, os
cfg, model = sys.argv[1], sys.argv[2]
data = {}
if os.path.exists(cfg):
    try:
        with open(cfg) as f:
            data = json.load(f)
    except Exception:
        data = {}
data.setdefault("$schema", "https://opencode.ai/config.json")
data["model"] = model
with open(cfg, "w") as f:
    json.dump(data, f, indent=2)
    f.write("\n")
PY
}

# Route Claude Code + OpenCode through Poe (Anthropic-compatible endpoint)
use-poe() {
    export ANTHROPIC_AUTH_TOKEN="$POE_API_KEY"
    export ANTHROPIC_BASE_URL="https://api.poe.com"
    export ANTHROPIC_API_KEY=""
    _set_opencode_model "poe/anthropic/claude-opus-4.7"
    echo "Switched to Poe. Claude Code routes to api.poe.com. OpenCode default: poe/anthropic/claude-opus-4.7"
}
alias use_poe=use-poe

# Claude Code uses Claude.ai subscription (OAuth from ~/.claude/.credentials.json).
# OpenCode falls back to Poe Claude because Anthropic TOS forbids subscription
# auth from third-party clients.
use-claude() {
    unset ANTHROPIC_API_KEY
    unset ANTHROPIC_AUTH_TOKEN
    unset ANTHROPIC_BASE_URL
    _set_opencode_model "poe/anthropic/claude-opus-4.7"
    echo "Switched to Claude subscription. Claude Code uses OAuth login. OpenCode falls back to poe/anthropic/claude-opus-4.7."
}
alias use_claude=use-claude

# Route Claude Code + OpenCode to direct Anthropic API (CLAUDE_API_KEY).
# Needs an Anthropic API credit balance at console.anthropic.com.
use-claude-api() {
    unset ANTHROPIC_AUTH_TOKEN
    unset ANTHROPIC_BASE_URL
    export ANTHROPIC_API_KEY="$CLAUDE_API_KEY"
    _set_opencode_model "anthropic/claude-opus-4-7"
    echo "Switched to direct Anthropic API. Claude Code routes to api.anthropic.com. OpenCode default: anthropic/claude-opus-4-7. (Needs Anthropic API credits.)"
}
alias use_claude_api=use-claude-api

