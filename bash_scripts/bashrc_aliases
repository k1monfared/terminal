# aichat wrappers
#   chat                                  REPL, resumes the rolling "default" session
#   chat "question"                       one-shot
#   chat -s research                      REPL, named session
#   chat -m gemini:gemini-2.5-pro "..."   one-shot on a specific model
#   chats                                 view invocation history (timestamp, model, session)
chat() {
    if [[ "$1" == "help" || "$1" == "-h" || "$1" == "--help" ]]; then
        cat <<'EOF'
chat cheatsheet

USAGE
  chat                              REPL, resumes the "default" rolling session
  chat "question"                   one-shot, no session
  chat -s NAME                      REPL, named session NAME (created if new)
  chat -m PROVIDER:MODEL "..."      one-shot on a specific model
  chat -m PROVIDER:MODEL -s NAME    REPL with both pinned
  chat help                         this cheatsheet
  chats                             view invocation history (less +G on the log)

REPL COMMANDS  (inside the chat)
  .model <TAB>                      switch model, tab-completes
  .session NAME                     open or resume a named session
  .info                             show current model and session
  .help                             full aichat REPL help
  .exit  / Ctrl-D                   save session and quit

PROVIDERS  (use as PROVIDER:MODEL with -m or inside REPL with .model)
  poe          Poe (uses bot names: Claude-Opus-4.7, Claude-Sonnet-4.6, GPT-5.4, Gemini-3.1-Pro, ...)
  claude       Direct Anthropic API (needs API credits)
  gemini       Google AI Studio (free tier)
  github       GitHub Models (free tier; 8k per-request cap)
  nvidia       NVIDIA build (free tier)
  cerebras     Cerebras (free tier; 8k per-request cap)
  openrouter   OpenRouter (many ":free" models, plus paid)
  mistral      Mistral La Plateforme (free tier)

LISTS
  aichat --list-models              all configured models
  aichat --list-sessions            all saved sessions
  aichat --sync-models              refresh aichat's model catalog

FILES
  ~/.config/aichat/config.yaml      add/remove models, set defaults
  ~/.config/aichat/sessions/        saved session transcripts
  ~/.config/aichat/messages.md      built-in flat log of one-shots
  ~/.config/aichat/invocations.log  what `chat` logs (timestamp, model, session)
EOF
        return 0
    fi

    local args=("$@")
    [[ ${#args[@]} -eq 0 ]] && args=(-s default)

    # Detect model and session from args for the invocation log
    local model="(config default)" session="(ephemeral)" i
    for (( i=0; i<${#args[@]}; i++ )); do
        case "${args[$i]}" in
            -m|--model)   model="${args[$((i+1))]}" ;;
            -s|--session) session="${args[$((i+1))]:-default}" ;;
        esac
    done

    mkdir -p "$HOME/.config/aichat"
    printf '%s\tmodel=%s\tsession=%s\targs=%s\n' \
        "$(date -Iseconds)" "$model" "$session" "${args[*]}" \
        >> "$HOME/.config/aichat/invocations.log"

    aichat "${args[@]}"
}
alias chats='less +G ~/.config/aichat/invocations.log'

# Print current AI routing for Claude Code and OpenCode
check-claude-config() {
    echo "Current configuration:"
    echo "  ANTHROPIC_API_KEY:    ${ANTHROPIC_API_KEY:+[SET]}"
    echo "  ANTHROPIC_AUTH_TOKEN: ${ANTHROPIC_AUTH_TOKEN:+[SET]}"
    echo "  ANTHROPIC_BASE_URL:   ${ANTHROPIC_BASE_URL:-[NOT SET]}"
    local cfg="$HOME/.config/opencode/opencode.json"
    if [[ -f "$cfg" ]]; then
        local m
        m=$(python3 -c "import json,sys; print(json.load(open(sys.argv[1])).get('model','[unset]'))" "$cfg" 2>/dev/null)
        echo "  OpenCode default:     ${m:-[parse error]}"
    else
        echo "  OpenCode default:     [no config file]"
    fi
}

